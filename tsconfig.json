{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"noEmit": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"types": ["node"]
	},
	"include": [
		"src/**/*",
		"static/**/*",
		"backend/**/*",
		"scripts/**/*"
	],
	"exclude": [
		"node_modules",
		".svelte-kit",
		"dist",
		"build",
		"**/*.spec.ts"
	]
}
